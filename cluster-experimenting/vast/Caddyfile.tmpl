# Reverse-proxy in front of the Ollama server on the Vast.ai box.
# Adds bearer-token auth (Ollama itself has no auth) and TLS.
# {$OLLAMA_AUTH_TOKEN} is interpolated by Caddy from the env at startup.
#
# Listening port: 8443 (the public-facing Vast port, mapped externally).
# Upstream:       127.0.0.1:11434 (Ollama, container-local only).

:8443 {
	tls internal

	@authed header Authorization "Bearer {$OLLAMA_AUTH_TOKEN}"
	handle @authed {
		reverse_proxy 127.0.0.1:11434 {
			# Ollama streams long responses; keep the connection open
			# for at least the longest plausible chat() call.
			transport http {
				read_timeout 1h
				write_timeout 1h
			}
		}
	}

	# Anything without the right Authorization header gets a flat 401.
	handle {
		respond "unauthorized" 401
	}
}
