	barge0 barge1 - barge
	pontoon0 pontoon1 pontoon2 pontoon3 pontoon4 pontoon5 - pontoon
	bale0 bale1 bale2 bale3 - bale
	derrick0 derrick1 derrick2 derrick3 derrick4 derrick5 - derrick)
(:init
	(moored_at pontoon0 dock0)
	(empty pontoon0)
	(moored_at pontoon1 dock1)
	(empty bale3)
	(moored_at pontoon2 dock2)
	(empty pontoon2)
	(moored_at pontoon3 wharf0)
	(empty bale2)
	(moored_at pontoon4 wharf1)
	(empty pontoon4)
	(moored_at pontoon5 wharf2)
	(empty bale0)
	(moored_at barge0 wharf1)
	(moored_at barge1 wharf1)
	(moored_at derrick0 dock0)
	(ready derrick0)
	(moored_at derrick1 dock1)
	(ready derrick1)
	(moored_at derrick2 dock2)
