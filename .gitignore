.DS_Store
__pycache__/
*.pyc
.idea/
.env
.envrc
.venv/
*.egg-info/
results/
.ipynb_checkpoints/
*.log

# Developer-local scratch (anchors, runbooks, ad-hoc reports). Holds the
# pre-refactor smoke-equality anchor (.local/anchors/) and the diff helper
# (.local/scripts/diff_smoke.sh) used by the PR-1 merge gate.
.local/

# Fast Downward / ENHSP intermediates. The pddl-solver plugin pins CWD to a
# per-request temp dir (pddl-copilot f4b8244), so current runs can't leak
# these — but an older plugin checkout would still write them to this dir.
output.sas
sas_plan*

# SLURM job logs (see cluster-experimenting/)
cluster-experimenting/logs/

# PlanBench arm — clones (LLMs-Planning, Fast Downward) and built binaries
# live here. Cloned + built per-host by planbench/setup.sh; never committed.
external/

# Checkpoint snapshots are stored as zip archives (results.zip, slurm_logs.zip).
# If a user unzips them locally for inspection, ignore the extracted JSON/out
# files so they aren't accidentally re-committed alongside the zips.
checkpoints/**/*.json
checkpoints/**/*.jsonl
checkpoints/**/*.out
checkpoints/**/*.png
checkpoints/**/*.md
checkpoints/**/*.pptx